{
    "$schema": "https://angular.io/config/angular.json",
    "version": 1,
    "projects": {
        "policy-lens": {
            "projectType": "application",
            "schematics": {},
            "root": "",
            "sourceRoot": "src",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:browser",
                    "options": {
                        "outputPath": "dist/policy-lens",
                        "index": "src/index.html",
                        "main": "src/main.ts",
                        "polyfills": [],
                        "tsConfig": "tsconfig.app.json",
                        "assets": [
                            "src/favicon.ico",
                            "src/assets"
                        ],
                        "styles": [
                            "src/styles.css"
                        ],
                        "scripts": []
                    }
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "options": {
                        "browserTarget": "policy-lens:build"
                    }
                }
            }
        }
    },
    "defaultProject": "policy-lens"
}